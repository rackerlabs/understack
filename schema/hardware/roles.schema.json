{
  "$defs": {
    "role": {
      "additionalProperties": false,
      "description": "A role definition for categorizing Nautobot resources",
      "properties": {
        "color": {
          "description": "Hex color code for the role (6 character hex string without # prefix)",
          "pattern": "^[0-9a-fA-F]{6}$",
          "type": "string"
        },
        "content_types": {
          "description": "List of Nautobot content types this role applies to (e.g., 'ipam.vlan', 'ipam.prefix', 'dcim.device')",
          "items": {
            "pattern": "^[a-z_]+\\.[a-z_]+$",
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "description": {
          "description": "Human-readable description of the role",
          "type": "string"
        },
        "name": {
          "description": "Unique name of the role",
          "minLength": 1,
          "type": "string"
        },
        "weight": {
          "description": "Numeric weight for ordering roles",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "name",
        "color",
        "description",
        "weight",
        "content_types"
      ],
      "type": "object"
    }
  },
  "$id": "https://rackerlabs.github.io/understack/schema/hardware/roles.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Role configuration schema for Nautobot resource role assignment",
  "items": {
    "$ref": "#/$defs/role"
  },
  "minItems": 1,
  "title": "UnderStack Roles",
  "type": "array"
}
