{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        }
      },
      "required": [
        "repository",
        "tag",
        "pullPolicy"
      ]
    },
    "serviceAccountName": {
      "type": "string",
      "minLength": 1
    },
    "nautobot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "configPath": {
          "type": "string"
        },
        "dbPasswordSecretRef": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "key": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "name",
            "key"
          ]
        },
        "envFromConfigMaps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "envFromSecrets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": [
        "dbPasswordSecretRef",
        "envFromConfigMaps",
        "envFromSecrets"
      ]
    },
    "job": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "restartPolicy": {
          "type": "string",
          "enum": [
            "OnFailure",
            "Never"
          ]
        },
        "backoffLimit": {
          "type": "integer",
          "minimum": 0
        },
        "ttlSecondsAfterFinished": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "restartPolicy",
        "backoffLimit",
        "ttlSecondsAfterFinished"
      ]
    },
    "cleanup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "groupName": {
          "type": "string",
          "minLength": 1
        },
        "deleteUserWhenNoManagedTokens": {
          "type": "boolean"
        }
      },
      "required": [
        "groupName",
        "deleteUserWhenNoManagedTokens"
      ]
    },
    "scriptConfigMapName": {
      "type": "string"
    },
    "tokens": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
          },
          "enabled": {
            "type": "boolean"
          },
          "sourceSecretRef": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "keys": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "username": {
                    "type": "string",
                    "minLength": 1
                  },
                  "email": {
                    "type": "string",
                    "minLength": 1
                  },
                  "password": {
                    "type": "string",
                    "minLength": 1
                  },
                  "apiToken": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "required": [
              "name"
            ]
          },
          "user": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "isSuperuser": {
                "type": "boolean"
              }
            }
          }
        },
        "required": [
          "name",
          "sourceSecretRef"
        ]
      }
    }
  },
  "required": [
    "image",
    "serviceAccountName",
    "nautobot",
    "job",
    "cleanup",
    "scriptConfigMapName",
    "tokens"
  ]
}
